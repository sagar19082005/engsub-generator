  "data_structure_explanation": {
    "title": "Word-by-Word Typing Effect Data Structure",
    "description": "Each word in the 'words' array must contain timing information and custom styling options",
    "fields": {
      "text": {
        "type": "string",
        "required": true,
        "description": "The word text to display"
      },
      "start": {
        "type": "number",
        "required": true,
        "description": "Time in seconds when the word should appear"
      },
      "end": {
        "type": "number",
        "required": true,
        "description": "Time in seconds when the word should disappear"
      },
      "customStyle": {
        "type": "object",
        "required": true,
        "description": "Individual styling for the word",
        "properties": {
          "color": {
            "type": "string",
            "format": "hex color",
            "default": "#ffffff",
            "description": "Text color in hex format (e.g., #FF0000)"
          },
          "font": {
            "type": "string",
            "default": "Arial",
            "description": "Font family name (e.g., Arial, Helvetica, Georgia)"
          },
          "size": {
            "type": "number",
            "default": 36,
            "description": "Font size in pixels"
          },
          "fontWeight": {
            "type": "string",
            "enum": ["normal", "bold", "100", "200", "300", "400", "500", "600", "700", "800", "900"],
            "default": "normal",
            "description": "Font weight"
          },
          "textDecoration": {
            "type": "string",
            "enum": ["none", "underline", "overline", "line-through"],
            "default": "none",
            "description": "Text decoration style"
          },
          "x": {
            "type": "number",
            "default": 0,
            "description": "Horizontal offset in pixels (relative positioning)"
          },
          "y": {
            "type": "number",
            "default": 0,
            "description": "Vertical offset in pixels (relative positioning)"
          },
          "opacity": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 1,
            "description": "Word opacity (0 = transparent, 1 = opaque)"
          }
        }
      }
    }
  }

# Server Configuration
PORT=3000

# Node Environment
NODE_ENV=production

# Upload Configuration
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# File Size Limits (in MB)
MAX_FILE_SIZE=500

# Whisper Configuration
WHISPER_MODEL=base
WHISPER_LANGUAGE=en

# FFmpeg Path (optional - leave blank to use system FFmpeg)
FFMPEG_PATH=

# CORS Configuration
CORS_ORIGIN=*
